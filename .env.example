# Copy this file to .env and fill in your actual passwords securely
CAMS_PASSWORD=your_cams_password_here
NPS_PASSWORD=your_nps_password_here

# LLM Configuration for AI Advisor
# Set LLM_PROVIDER to "gemini" (Ollama support removed — use Gemini only)
LLM_PROVIDER=gemini

# Gemini API — get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model: gemini-3.1-flash-lite-preview (released Mar 3 2026, preview)
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Kaggle API credentials — used for Indian MF Dataset enrichment (optional)
# Set up: https://www.kaggle.com/docs/api — place kaggle.json in ~/.kaggle/
# OR set env vars directly:
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
